# ─── Firebase Client (публичные ключи) ───────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Firebase Admin (серверные ключи) ────────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Groq API ─────────────────────────────────────────────────────────────────
# Ротация ключей: добавь до 15 ключей (GROQ_API_KEY_1 ... GROQ_API_KEY_15)
# При rate limit (429) автоматически переключается на следующий ключ
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# ... до GROQ_API_KEY_20

# Основная модель — высокое качество, reasoning (шаги 3+4)
# Альтернативы: qwen/qwen3-32b | llama-3.3-70b-versatile
GROQ_MODEL=openai/gpt-oss-120b

# Быстрая модель — скорость (шаги 1+2 и DA)
# Альтернативы: qwen/qwen3-32b | llama-3.3-70b-versatile
GROQ_MODEL_FAST=openai/gpt-oss-20b

# ─── Telegram уведомления ────────────────────────────────────────────────────
# Как получить:
#   1. @BotFather в Telegram → /newbot → скопировать токен
#   2. @userinfobot → /start → скопировать Id
#   3. Открыть своего бота и нажать /start (иначе бот не сможет писать)
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ─── Администратор ───────────────────────────────────────────────────────────
# Email(s) через запятую, которым доступна /admin панель
ADMIN_EMAILS=kotvukai@gmail.com

# ─── Авто-анализ (24/7) ──────────────────────────────────────────────────────
# Секретный ключ для защиты /api/analyze/auto и /api/telegram/webhook
# Генерация: openssl rand -hex 32
AUTO_ANALYZE_SECRET=your_secret_key_here

# Публичный URL приложения (для GitHub Actions и статус-сообщений в боте)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
